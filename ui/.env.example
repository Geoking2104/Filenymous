# ── Holochain conductor ───────────────────────────────────────────────────────
# WebSocket URL exposed by the Holochain conductor
VITE_HC_URL=ws://localhost:8888

# ── Bridge micro-service ──────────────────────────────────────────────────────
VITE_BRIDGE_URL=http://localhost:3001

# Shared HMAC secret — must match BRIDGE_SECRET in bridge/.env
VITE_BRIDGE_SECRET=change-me-in-production
