# Filenymous — Caddy reverse proxy
#
# IMPORTANT: kitsune2-bootstrap-srv handles its own TLS on port 443.
# Caddy is only used for the bridge notification service.
#
# DNS records required:
#   bootstrap.filenymous.app  A  <your-server-ip>  ← direct to kitsune2 (port 443)
#   bridge.filenymous.app     A  <your-server-ip>  ← Caddy (port 8443)
#
# If your server only has one IP, use different ports or subdomains pointing
# to port 443 (kitsune2) vs 8443 (Caddy → bridge).

# ── Bridge (notification REST API) ──────────────────────────────────────────
bridge.filenymous.app {
    reverse_proxy bridge:3001
    log { output stdout }
}
