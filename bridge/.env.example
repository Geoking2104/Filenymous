# ── Bridge ────────────────────────────────────────────────────────────────────
PORT=3001
HOST=0.0.0.0

# Secret partagé entre bridge et conductor (min 32 chars en production)
BRIDGE_SECRET=change-me-in-production

# ── Email — livraison SMTP directe (aucun service tiers) ─────────────────────
# Nodemailer résout les MX du destinataire et livre directement.
# Aucune API key requise.

# Domaine annoncé dans EHLO — doit correspondre au PTR de l'IP du serveur
MAIL_HOSTNAME=filenymous.app

# Adresse expéditeur
FROM_EMAIL=noreply@filenymous.app
FROM_NAME=Filenymous

# ── DKIM (optionnel — améliore la délivrabilité, évite les spams) ─────────────
# 1. Générer : openssl genrsa -out dkim_private.pem 2048
# 2. Extraire la clé publique : openssl rsa -in dkim_private.pem -pubout
# 3. Publier en DNS : mail._domainkey.<DKIM_DOMAIN> TXT "v=DKIM1; k=rsa; p=<clé_publique>"
# 4. Injecter ici (remplacer les sauts de ligne par \n)
#DKIM_DOMAIN=filenymous.app
#DKIM_SELECTOR=mail
#DKIM_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----
